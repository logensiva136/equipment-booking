# Copy to .env and fill in the real backend URL for each environment.
# .env itself is gitignored -- never commit real values here.
#
# NOTE: Vite bakes VITE_* vars into the built JS bundle at build time,
# not read at server start like a backend env var. Changing this after
# building requires a rebuild (or, for Docker, passing it as a build-arg)
# -- it can't be swapped at container/deploy time like DJANGO_* vars can.

VITE_API_URL=http://localhost:8000/api
