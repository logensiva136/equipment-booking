# Copy to .env and fill in real values for each environment. .env itself
# is gitignored -- never commit real secrets.

# Generate a fresh one per environment, e.g.:
#   uv run python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=

# true/false. Must be false in production.
DJANGO_DEBUG=true

# Comma-separated list of hostnames this backend is served from, e.g.
# api.example.com. Required (and enforced) once DJANGO_DEBUG=false.
DJANGO_ALLOWED_HOSTS=

# Comma-separated list of the frontend's actual origin(s), e.g.
# https://app.example.com. Must include the scheme, no trailing slash.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
